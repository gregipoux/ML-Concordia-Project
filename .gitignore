# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg

# Virtual environments
venv/
env/
.env

# IDE
.idea/
.vscode/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Data (keep CSV tracked for this project, but ignore large files)
data/*.zip
data/*.tar.gz

# MLflow
mlruns/
mlflow/mlruns/

# Docker
docker/*.tar

# OS
.DS_Store
Thumbs.db

# Models — the saved_models/ bundle is committed so `docker compose up -d`
# works on a fresh clone / ZIP without a training step. Other .h5 / .pkl
# (notebook checkpoints, TF snapshots elsewhere in the repo) stay out.
*.h5
*.pkl
!saved_models/best_model.joblib
!saved_models/dnn.weights.h5

# Reports build artifacts
reports/*.aux
reports/*.log

# Submission artifacts (generated outside the repo via git archive)
*.zip
!data/*.csv

ADVANCED_USE_CASES.md